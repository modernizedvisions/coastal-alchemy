# Stripe (server-side Workers)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Client-side publishable key (only used in the browser)
VITE_STRIPE_PUBLISHABLE_KEY=

# Site config
VITE_PUBLIC_SITE_URL=
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin auth (PBKDF2 + D1 sessions)
# Set these in Cloudflare Pages secrets/variables for production.
ADMIN_PASSWORD_SALT_B64=
ADMIN_PASSWORD_HASH_B64=
ADMIN_PASSWORD_ITERS=10000
ADMIN_SESSION_TTL_DAYS=14

# Image uploads (R2)
# IMAGES_BUCKET is an R2 binding (configured in Cloudflare Pages/Workers), not a raw env var.
PUBLIC_IMAGES_BASE_URL=

# Product video uploads (Cloudflare Stream)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_ALLOWED_ORIGINS=
CLOUDFLARE_STREAM_MAX_DURATION_SECONDS=15
CLOUDFLARE_STREAM_MAX_FILE_SIZE_MB=50
CLOUDFLARE_STREAM_UPLOAD_EXPIRY_MINUTES=30
CLOUDFLARE_STREAM_REQUIRE_SIGNED_URLS=false
